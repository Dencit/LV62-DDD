# 微信 支付 设置
WX_PAY_APP_ID =
WX_PAY_APP_SECRET =
WX_PAY_MCH_ID = 12345678
WX_PAY_KEY = demo2018
WX_PAY_SSL_CERT_PATH = extend/WxPayApi/cert/apiclient_cert.pem
WX_PAY_SSL_KEY_PATH = extend/WxPayApi/cert/cert/apiclient_key.pem
