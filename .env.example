APP_NAME=Laravel
APP_ENV=local
APP_KEY=123456
APP_DEBUG=true
APP_URL=http://localhost

LOG_CHANNEL=stack

DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3306
DB_DATABASE=laravel
DB_USERNAME=root
DB_PASSWORD=

BROADCAST_DRIVER=log
CACHE_DRIVER=file
QUEUE_CONNECTION=sync
SESSION_DRIVER=file
SESSION_LIFETIME=120

REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_DRIVER=smtp
MAIL_HOST=smtp.mailtrap.io
MAIL_PORT=2525
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=null
MAIL_FROM_ADDRESS=null
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=

PUSHER_APP_ID=
PUSHER_APP_KEY=
PUSHER_APP_SECRET=
PUSHER_APP_CLUSTER=mt1

MIX_PUSHER_APP_KEY="${PUSHER_APP_KEY}"
MIX_PUSHER_APP_CLUSTER="${PUSHER_APP_CLUSTER}"

ELASTICE_SEARCH_HOST = 'http://127.0.0.1:9268'





# 阿里云 设置
ALIYUN_ACCESS_KEY_ID =
ALIYUN_ACCESS_KEY_SECRET =

# 阿里云 对象存储 设置
OSS_HTTPS = 0
OSS_BASE_HOST = oss-cn-shenzhen.aliyuncs.com
OSS_BUCKET = demo-file-buck
OSS_MPS_BUCKET = demo-mps-buck
OSS_PIC_SMALL = !small
OSS_PIC_NORMAL = !normal
OSS_CDN = 0
OSS_BUCKET_CDN = demo-file-buck.oss-accelerate.aliyuncs.com
OSS_MPS_BUCKET_CDN = mps-dev.demo.com

# 阿里支付宝 设置
ALI_PAY_APP_ID =
ALI_PAY_PAYMENT_RSA_PUBLIC_KEY_PEM = extend/AliPaySdk/cert/alipay_public_key.pem
ALI_PAY_RSA_PUBLIC_KEY_PEM = extend/AliPaySdk/cert/rsa_public_key.pem
ALI_PAY_RSA_PRIVATE_KEY_PEM = extend/AliPaySdk/cert/rsa_private_key.pem
ALI_PAY_GATEWAY_URL = https://openapi.alipaydev.com/gateway.do
ALI_PAY_NOTIFY_URL =
ALI_PAY_TIMEOUT_EXPRESS = 30M

# 阿里云 大鱼短信 设置
SMS_SIGN_NAME = "企业平台名"
SMS_CODE_TPL =

# 阿里云 消息服务 设置
